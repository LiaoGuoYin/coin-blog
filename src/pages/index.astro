---
import Layout from '../layouts/Layout.astro';
import { getAllPosts } from '../lib/posts';
import { siteConfig } from '../lib/config';
import PostListDivided from '../components/PostListDivided.astro';
import PostListTwoLine from '../components/PostListTwoLine.astro';
import PostListPreview from '../components/PostListPreview.astro';

const allPosts = getAllPosts();
const style = siteConfig.postListStyle;
---

<Layout title={siteConfig.title}>
  <div class="p-5 sm:p-8 flex flex-col gap-4">
    <section>
      <h2 class="text-base font-semibold mb-4" style="color: var(--bronze-12);">
        {siteConfig.ui.postsHeading}
      </h2>

      {style === 'divided' && <PostListDivided posts={allPosts} />}
      {style === 'twoLine' && <PostListTwoLine posts={allPosts} />}
      {style === 'preview' && <PostListPreview posts={allPosts} />}
    </section>
  </div>
</Layout>

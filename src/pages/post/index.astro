---
import Layout from '../../layouts/Layout.astro';
import { getAllPosts } from '../../lib/posts';
import { siteConfig } from '../../lib/config';
import PostListDivided from '../../components/PostListDivided.astro';
import PostListTwoLine from '../../components/PostListTwoLine.astro';
import PostListPreview from '../../components/PostListPreview.astro';

const posts = getAllPosts();
const style = siteConfig.postListStyle;
---

<Layout title={`${siteConfig.ui.allPostsHeading} — ${siteConfig.title}`}>
  <div class="p-5 sm:p-8 flex flex-col gap-6">
    <section>
      <h2 class="text-base font-semibold mb-4" style="color: var(--bronze-12);">
        {siteConfig.ui.allPostsHeading}
      </h2>
      {posts.length > 0 ? (
        <>
          {style === 'divided' && <PostListDivided posts={posts} />}
          {style === 'twoLine' && <PostListTwoLine posts={posts} />}
          {style === 'preview' && <PostListPreview posts={posts} />}
        </>
      ) : (
        <p class="text-sm" style="color: var(--sand-11);">{siteConfig.ui.noPosts}</p>
      )}
    </section>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { getAllPosts, getAllMemos, formatDate } from '../lib/posts';
import { renderMarkdown } from '../lib/markdown';
import type { Post } from '../lib/posts';

export async function getStaticPaths() {
  const posts = getAllPosts();
  const memos = getAllMemos();
  const all: Post[] = [...posts, ...memos];

  return all.map((item) => ({
    params: { slug: item.slug },
    props: { post: item },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { html: contentHtml, headings } = await renderMarkdown(post.content);
const pageTitle = `${post.title} — Coin's Blog`;
---

<Layout title={pageTitle}>
  <article class="post-article">
    <!-- Post header -->
    <header class="post-header">
      <a
        href={post.type === 'memo' ? '/memo' : '/post'}
        class="post-back"
      >
        ← {post.type === 'memo' ? 'Memos' : 'Posts'}
      </a>
      <h1 class="post-title">{post.title}</h1>
      <p class="post-date">{formatDate(post.date)}</p>
    </header>

    <!-- Body: content + TOC -->
    <div class="post-body">
      <div class="prose dark:prose-invert max-w-none" set:html={contentHtml} />

      {headings.length > 0 && (
        <nav class="post-toc">
          <p class="toc-label">本文导览</p>
          <ul>
            {headings.map((h) => (
              <li class={h.level === 3 ? 'toc-h3' : 'toc-h2'}>
                <a href={`#${h.id}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </div>
  </article>
</Layout>

<style>
  .post-article {
    padding: 1.25rem 1rem 3rem;
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }

  @media (min-width: 640px) {
    .post-article {
      padding: 2rem 1.75rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .post-article {
      padding: 2.5rem 2.5rem 4rem;
    }
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--sand-5);
    max-width: 52rem;
  }

  @media (min-width: 1024px) {
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
    }
  }

  .post-back {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--grass-11);
    text-decoration: none;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .post-back:hover {
    color: var(--grass-10);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--sand-9);
    margin: 0 0 0.6rem;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--bronze-12);
    margin: 0;
  }

  @media (min-width: 640px) {
    .post-title { font-size: 1.75rem; }
  }

  @media (min-width: 1024px) {
    .post-title { font-size: 2rem; }
  }

  /* Body layout: content + TOC side by side */
  .post-body {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .post-body .yue {
    flex: 1;
    min-width: 0;
    max-width: 52rem;
  }

  /* TOC */
  .post-toc {
    flex-shrink: 0;
    width: 13rem;
    position: sticky;
    top: 1.5rem;
    display: none;
  }

  @media (min-width: 1100px) {
    .post-toc {
      display: block;
    }
  }

  .toc-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sand-9);
    margin: 0 0 0.75rem;
  }

  .post-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--sand-5);
  }

  .post-toc li {
    margin: 0;
  }

  .post-toc a {
    display: block;
    padding: 0.25rem 0 0.25rem 0.875rem;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--sand-10);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-toc a:hover {
    color: var(--sand-12);
  }

  .toc-h3 a {
    padding-left: 1.5rem;
    color: var(--sand-8);
  }

  .toc-h3 a:hover {
    color: var(--sand-11);
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import { getAllPosts, formatDate, estimateReadingTime } from '../lib/posts';
import { renderMarkdown } from '../lib/markdown';
import { siteConfig } from '../lib/config';
import type { Post, PostMeta } from '../lib/posts';

export async function getStaticPaths() {
  const posts = getAllPosts();

  return posts.map((item) => {
    const idx = posts.findIndex((s) => s.slug === item.slug);
    const prev = idx < posts.length - 1 ? posts[idx + 1] : null;
    const next = idx > 0 ? posts[idx - 1] : null;

    return {
      params: { slug: item.slug },
      props: { post: item, prev, next },
    };
  });
}

interface Props {
  post: Post;
  prev: PostMeta | null;
  next: PostMeta | null;
}

const { post, prev, next } = Astro.props;
const { html: contentHtml, headings } = await renderMarkdown(post.content);
const pageTitle = `${post.title} — ${siteConfig.title}`;
const readingTime = estimateReadingTime(post.content);
---

<Layout title={pageTitle} description={post.title} ogType="article">
  <article class="post-article" data-copy-label={siteConfig.ui.copyButton} data-copied-label={siteConfig.ui.copiedButton}>
    <!-- Post header -->
    <header class="post-header">
      <a href="/post" class="post-back">
        ← {siteConfig.ui.postsHeading}
      </a>
      <h1 class="post-title">{post.title}</h1>
      <p class="post-date">{formatDate(post.date)} · {siteConfig.ui.readingTime(readingTime)}</p>
    </header>

    <!-- Body: content + TOC -->
    <div class="post-body">
      <div class="prose max-w-none" set:html={contentHtml} />

      {headings.length > 0 && (
        <nav class="post-toc">
          <p class="toc-label">{siteConfig.ui.tocLabel}</p>
          <div class="toc-list-wrapper">
            <div class="toc-progress" id="toc-progress"></div>
            <ul>
              {headings.map((h) => (
                <li class={h.level === 3 ? 'toc-h3' : 'toc-h2'}>
                  <a href={`#${h.id}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )}
    </div>

    <!-- Prev / Next navigation -->
    {(prev || next) && (
      <nav class="post-nav">
        {prev ? (
          <a href={`/${prev.slug}`} class="post-nav-link post-nav-prev">
            <span class="post-nav-label">{siteConfig.ui.prevPost}</span>
            <span class="post-nav-title">{prev.title}</span>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/${next.slug}`} class="post-nav-link post-nav-next">
            <span class="post-nav-label">{siteConfig.ui.nextPost}</span>
            <span class="post-nav-title">{next.title}</span>
          </a>
        ) : <div />}
      </nav>
    )}
  </article>

  <!-- Back to top button -->
  <button class="back-to-top" id="back-to-top" aria-label={siteConfig.ui.backToTop}>↑</button>
</Layout>

<style>
  .post-article {
    padding: 1.25rem;
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }

  @media (min-width: 640px) {
    .post-article {
      padding: 2rem;
    }
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--sand-5);
  }

  @media (min-width: 1024px) {
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
    }
  }

  .post-back {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--bronze-11);
    text-decoration: none;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .post-back:hover {
    color: var(--bronze-9);
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--sand-9);
    margin: 0 0 0.6rem;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--bronze-12);
    margin: 0;
  }

  @media (min-width: 640px) {
    .post-title { font-size: 1.75rem; }
  }

  @media (min-width: 1024px) {
    .post-title { font-size: 2rem; }
  }

  /* Body layout: content + TOC side by side */
  .post-body {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .post-body > .prose {
    flex: 1;
    min-width: 0;
  }

  /* TOC */
  .post-toc {
    flex-shrink: 0;
    width: 13rem;
    position: sticky;
    top: 1.5rem;
    display: none;
  }

  @media (min-width: 1100px) {
    .post-toc {
      display: block;
    }
  }

  @media (min-width: 1440px) {
    .post-toc {
      width: 16rem;
    }
  }

  .toc-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sand-9);
    margin: 0 0 0.75rem;
  }

  .toc-list-wrapper {
    position: relative;
  }

  .toc-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0%;
    background-color: var(--bronze-9);
    border-radius: 1px;
    z-index: 1;
    transition: height 100ms linear;
  }

  .post-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--sand-5);
    border-radius: 1px;
  }

  .post-toc li {
    margin: 0;
  }

  .post-toc a {
    display: block;
    padding: 0.25rem 0 0.25rem 0.875rem;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--sand-10);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-toc a:hover {
    color: var(--sand-12);
  }

  .toc-h3 a {
    padding-left: 1.5rem;
    color: var(--sand-8);
  }

  .toc-h3 a:hover {
    color: var(--sand-11);
  }

  /* TOC active highlight */
  .post-toc a.active {
    color: var(--bronze-12);
    font-weight: 600;
  }

  /* Prev / Next navigation */
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sand-5);
    max-width: none;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    max-width: 45%;
  }

  .post-nav-next {
    margin-left: auto;
    text-align: right;
  }

  .post-nav-label {
    font-size: 0.75rem;
    color: var(--sand-9);
    letter-spacing: 0.02em;
  }

  .post-nav-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--bronze-12);
    line-height: 1.4;
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--bronze-11);
  }

  /* Back to top button */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--sand-5);
    border-radius: var(--radius-md);
    background-color: var(--sand-1);
    color: var(--sand-11);
    font-size: 1rem;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 40;
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .back-to-top:hover {
    background-color: var(--sand-3);
    color: var(--sand-12);
  }

</style>

<script>
  const tocProgress = document.getElementById('toc-progress');
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.post-toc a');
  const headingEls = Array.from(
    document.querySelectorAll<HTMLElement>('.prose h2[id], .prose h3[id]')
  );

  // Find the scroll container
  function findScrollContainer(el: Element | null): HTMLElement | Window {
    let node = el?.parentElement;
    while (node) {
      const style = getComputedStyle(node);
      if (style.overflowY === 'auto' || style.overflowY === 'scroll') {
        return node;
      }
      node = node.parentElement;
    }
    return window;
  }

  const article = document.querySelector('.post-article');
  const scrollContainer = findScrollContainer(article);

  function getScrollTop(): number {
    return scrollContainer instanceof HTMLElement
      ? scrollContainer.scrollTop
      : window.scrollY;
  }

  // --- IntersectionObserver for TOC active heading tracking ---
  let currentActiveId = '';

  function setActiveHeading(id: string) {
    if (id === currentActiveId) return;
    currentActiveId = id;
    tocLinks.forEach((link) => link.classList.remove('active'));
    if (id) {
      const activeLink = document.querySelector<HTMLAnchorElement>(
        `.post-toc a[href="#${id}"]`
      );
      activeLink?.classList.add('active');
    }
  }

  if (headingEls.length > 0) {
    // Track which headings are currently intersecting
    const visibleHeadings = new Set<string>();

    const observerRoot = scrollContainer instanceof HTMLElement ? scrollContainer : null;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const id = (entry.target as HTMLElement).id;
          if (entry.isIntersecting) {
            visibleHeadings.add(id);
          } else {
            visibleHeadings.delete(id);
          }
        }

        // Pick the first visible heading in document order
        if (visibleHeadings.size > 0) {
          for (const heading of headingEls) {
            if (visibleHeadings.has(heading.id)) {
              setActiveHeading(heading.id);
              return;
            }
          }
        }

        // No heading is intersecting — determine direction from the last entry
        // If we scrolled past all visible headings downward, find the last heading above the viewport
        const scrollTop = getScrollTop();
        const offset = scrollContainer instanceof HTMLElement ? scrollContainer.getBoundingClientRect().top : 0;
        let lastAbove = '';
        for (const heading of headingEls) {
          const rect = heading.getBoundingClientRect();
          if (rect.top - offset <= 0) {
            lastAbove = heading.id;
          }
        }
        if (lastAbove) {
          setActiveHeading(lastAbove);
        }
      },
      {
        root: observerRoot,
        // rootMargin: negative top margin so a heading counts as "active"
        // once it passes ~80px from the top; bottom extends fully
        rootMargin: '-80px 0px 0px 0px',
        threshold: 0,
      }
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  // --- Progress bar (lightweight scroll listener, no DOM queries in loop) ---
  function updateProgress() {
    if (!tocProgress) return;
    let scrollHeight: number, clientHeight: number;
    if (scrollContainer instanceof HTMLElement) {
      scrollHeight = scrollContainer.scrollHeight;
      clientHeight = scrollContainer.clientHeight;
    } else {
      scrollHeight = document.documentElement.scrollHeight;
      clientHeight = window.innerHeight;
    }
    const scrollTop = getScrollTop();

    // If at bottom, also ensure last heading is active
    const atBottom = scrollTop + clientHeight >= scrollHeight - 2;
    if (atBottom && headingEls.length > 0) {
      setActiveHeading(headingEls[headingEls.length - 1].id);
    }

    const scrollProgress = scrollHeight - clientHeight > 0
      ? (scrollTop / (scrollHeight - clientHeight)) * 100
      : 0;
    tocProgress.style.height = `${Math.min(scrollProgress, 100)}%`;
  }

  (scrollContainer instanceof HTMLElement ? scrollContainer : window)
    .addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // Back to top button
  const backToTop = document.getElementById('back-to-top');
  function updateBackToTop() {
    const scrollTop = getScrollTop();
    backToTop?.classList.toggle('visible', scrollTop > 400);
  }
  (scrollContainer instanceof HTMLElement ? scrollContainer : window)
    .addEventListener('scroll', updateBackToTop, { passive: true });
  backToTop?.addEventListener('click', () => {
    if (scrollContainer instanceof HTMLElement) {
      scrollContainer.scrollTo({ top: 0, behavior: 'smooth' });
    } else {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Heading anchor links (click to copy URL)
  headingEls.forEach((h) => {
    const anchor = document.createElement('a');
    anchor.className = 'heading-anchor';
    anchor.href = `#${h.id}`;
    anchor.textContent = '#';
    anchor.addEventListener('click', async (e) => {
      e.preventDefault();
      const url = `${location.origin}${location.pathname}#${h.id}`;
      await navigator.clipboard.writeText(url);
      anchor.textContent = '✓';
      setTimeout(() => { anchor.textContent = '#'; }, 1500);
    });
    h.prepend(anchor);
  });

  // Code block copy buttons
  const copyLabel = article?.getAttribute('data-copy-label') || 'Copy';
  const copiedLabel = article?.getAttribute('data-copied-label') || 'Copied';

  document.querySelectorAll('.prose .shiki').forEach((block) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'shiki-wrapper';
    block.parentNode!.insertBefore(wrapper, block);
    wrapper.appendChild(block);

    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = copyLabel;
    btn.addEventListener('click', async () => {
      const code = block.querySelector('code')?.textContent || '';
      await navigator.clipboard.writeText(code);
      btn.textContent = copiedLabel;
      setTimeout(() => { btn.textContent = copyLabel; }, 1500);
    });
    wrapper.appendChild(btn);
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import { getAllPosts, getAllMemos, formatDate } from '../lib/posts';
import { renderMarkdown } from '../lib/markdown';
import type { Post } from '../lib/posts';

export async function getStaticPaths() {
  const posts = getAllPosts();
  const memos = getAllMemos();
  const all: Post[] = [...posts, ...memos];

  return all.map((item) => ({
    params: { slug: item.slug },
    props: { post: item },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { html: contentHtml, headings } = await renderMarkdown(post.content);
const pageTitle = `${post.title} — Coin's Blog`;
---

<Layout title={pageTitle}>
  <article class="post-article">
    <!-- Post header -->
    <header class="post-header">
      <a
        href={post.type === 'memo' ? '/memo' : '/post'}
        class="post-back"
      >
        ← {post.type === 'memo' ? 'Memos' : 'Posts'}
      </a>
      <h1 class="post-title">{post.title}</h1>
      <p class="post-date">{formatDate(post.date)}</p>
    </header>

    <!-- Body: content + TOC -->
    <div class="post-body">
      <div class="prose dark:prose-invert max-w-none" set:html={contentHtml} />

      {headings.length > 0 && (
        <nav class="post-toc">
          <p class="toc-label">本文导览</p>
          <div class="toc-list-wrapper">
            <div class="toc-progress" id="toc-progress"></div>
            <ul>
              {headings.map((h) => (
                <li class={h.level === 3 ? 'toc-h3' : 'toc-h2'}>
                  <a href={`#${h.id}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )}
    </div>
  </article>
</Layout>

<style>
  .post-article {
    padding: 1.25rem 1rem 3rem;
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }

  @media (min-width: 640px) {
    .post-article {
      padding: 2rem 1.75rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .post-article {
      padding: 2.5rem 2.5rem 4rem;
    }
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--sand-5);
    max-width: 52rem;
  }

  @media (min-width: 1024px) {
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
    }
  }

  .post-back {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--grass-11);
    text-decoration: none;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .post-back:hover {
    color: var(--grass-10);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--sand-9);
    margin: 0 0 0.6rem;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--bronze-12);
    margin: 0;
  }

  @media (min-width: 640px) {
    .post-title { font-size: 1.75rem; }
  }

  @media (min-width: 1024px) {
    .post-title { font-size: 2rem; }
  }

  /* Body layout: content + TOC side by side */
  .post-body {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .post-body .yue {
    flex: 1;
    min-width: 0;
    max-width: 52rem;
  }

  /* TOC */
  .post-toc {
    flex-shrink: 0;
    width: 13rem;
    position: sticky;
    top: 1.5rem;
    display: none;
  }

  @media (min-width: 1100px) {
    .post-toc {
      display: block;
    }
  }

  .toc-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sand-9);
    margin: 0 0 0.75rem;
  }

  .toc-list-wrapper {
    position: relative;
  }

  .toc-progress {
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0%;
    background-color: var(--bronze-9);
    border-radius: 1px;
    z-index: 1;
    transition: height 100ms linear;
  }

  .post-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid var(--sand-5);
    border-radius: 1px;
  }

  .post-toc li {
    margin: 0;
  }

  .post-toc a {
    display: block;
    padding: 0.25rem 0 0.25rem 0.875rem;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--sand-10);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-toc a:hover {
    color: var(--sand-12);
  }

  .toc-h3 a {
    padding-left: 1.5rem;
    color: var(--sand-8);
  }

  .toc-h3 a:hover {
    color: var(--sand-11);
  }

  /* TOC active highlight */
  .post-toc a.active {
    color: var(--bronze-12);
    font-weight: 600;
  }

</style>

<script>
  const tocProgress = document.getElementById('toc-progress');
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.post-toc a');
  const headingEls = Array.from(
    document.querySelectorAll<HTMLElement>('.prose h2[id], .prose h3[id]')
  );

  // Find the scroll container
  function findScrollContainer(el: Element | null): HTMLElement | Window {
    let node = el?.parentElement;
    while (node) {
      const style = getComputedStyle(node);
      if (style.overflowY === 'auto' || style.overflowY === 'scroll') {
        return node;
      }
      node = node.parentElement;
    }
    return window;
  }

  const article = document.querySelector('.post-article');
  const scrollContainer = findScrollContainer(article);

  function getScrollTop(): number {
    return scrollContainer instanceof HTMLElement
      ? scrollContainer.scrollTop
      : window.scrollY;
  }

  function update() {
    if (!tocProgress || headingEls.length === 0) return;

    const scrollTop = getScrollTop();
    const offset = scrollContainer instanceof HTMLElement ? scrollContainer.getBoundingClientRect().top : 0;

    // Find which heading we've scrolled past
    let scrollHeight: number, clientHeight: number;
    if (scrollContainer instanceof HTMLElement) {
      scrollHeight = scrollContainer.scrollHeight;
      clientHeight = scrollContainer.clientHeight;
    } else {
      scrollHeight = document.documentElement.scrollHeight;
      clientHeight = window.innerHeight;
    }
    const atBottom = scrollTop + clientHeight >= scrollHeight - 2;

    let activeIndex = -1;
    if (atBottom) {
      activeIndex = headingEls.length - 1;
    } else {
      for (let i = headingEls.length - 1; i >= 0; i--) {
        const rect = headingEls[i].getBoundingClientRect();
        const top = rect.top - offset;
        if (top <= 80) {
          activeIndex = i;
          break;
        }
      }
    }

    // Update TOC active link
    tocLinks.forEach((link) => link.classList.remove('active'));
    if (activeIndex >= 0) {
      const activeHeading = headingEls[activeIndex];
      const activeLink = document.querySelector<HTMLAnchorElement>(
        `.post-toc a[href="#${activeHeading.id}"]`
      );
      activeLink?.classList.add('active');
    }

    // Update progress bar height based on overall scroll percentage
    const scrollProgress = scrollHeight - clientHeight > 0
      ? (scrollTop / (scrollHeight - clientHeight)) * 100
      : 0;
    tocProgress.style.height = `${Math.min(scrollProgress, 100)}%`;
  }

  (scrollContainer instanceof HTMLElement ? scrollContainer : window)
    .addEventListener('scroll', update, { passive: true });
  update();

  // Code block copy buttons
  document.querySelectorAll('.prose .shiki').forEach((block) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'shiki-wrapper';
    block.parentNode!.insertBefore(wrapper, block);
    wrapper.appendChild(block);

    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = '复制';
    btn.addEventListener('click', async () => {
      const code = block.querySelector('code')?.textContent || '';
      await navigator.clipboard.writeText(code);
      btn.textContent = '已复制';
      setTimeout(() => { btn.textContent = '复制'; }, 1500);
    });
    wrapper.appendChild(btn);
  });
</script>

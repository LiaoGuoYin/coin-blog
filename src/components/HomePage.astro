---
import Layout from '../layouts/Layout.astro';
import { getAllPosts } from '../lib/posts';
import { siteConfig } from '../lib/config';
import PostListDivided from './PostListDivided.astro';
import PostListTwoLine from './PostListTwoLine.astro';
import PostListPreview from './PostListPreview.astro';

const allPosts = getAllPosts();
const style = siteConfig.postListStyle;
---

<Layout title={siteConfig.title}>
  <div class="p-5 sm:p-8 flex flex-col gap-4">
    <!-- Posts tab -->
    <section id="tab-posts">
      <h2 class="text-base font-semibold mb-4" style="color: var(--bronze-12);">
        {siteConfig.ui.postsHeading}
      </h2>

      {style === 'divided' && <PostListDivided posts={allPosts} />}
      {style === 'twoLine' && <PostListTwoLine posts={allPosts} />}
      {style === 'preview' && <PostListPreview posts={allPosts} />}
    </section>

    <!-- Memos tab -->
    <section id="tab-memos" class="tab-hidden" data-api={siteConfig.memosApiUrl}>
      <h2 class="text-base font-semibold mb-4" style="color: var(--bronze-12);">
        {siteConfig.ui.memosHeading}
      </h2>

      <!-- Loading skeleton -->
      <div id="memo-loading" class="timeline">
        {Array.from({ length: 5 }).map(() => (
          <div class="tl-item">
            <span class="tl-dot"></span>
            <div class="tl-content">
              <div class="skeleton skeleton-date"></div>
              <div class="skeleton skeleton-body"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Error state -->
      <p id="memo-error" class="text-sm tab-hidden" style="color: var(--sand-11);">
        {siteConfig.ui.noMemos}
      </p>

      <!-- Memo list (populated by JS) -->
      <div id="memo-list" class="timeline tab-hidden"></div>
    </section>
  </div>
</Layout>

<style is:global>
  .tab-hidden {
    display: none !important;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 1.5rem;
  }

  /* Continuous vertical line */
  .timeline::before {
    content: '';
    position: absolute;
    left: 3px;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background-color: var(--sand-5);
    border-radius: 1px;
  }

  .tl-item {
    position: relative;
    padding-bottom: 1rem;
  }

  .tl-item:last-child {
    padding-bottom: 0;
  }

  /* Dot / anchor button on the timeline */
  .tl-dot {
    position: absolute;
    left: -1.5rem;
    top: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--sand-6);
    transition: background-color 0.2s, transform 0.2s;
    z-index: 1;
    border: none;
    padding: 0;
  }

  button.tl-anchor {
    cursor: pointer;
    /* Larger hit area for easier clicking */
    width: 20px;
    height: 20px;
    left: calc(-1.5rem - 6px);
    top: -6px;
    background: transparent;
  }

  button.tl-anchor::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--sand-6);
    transition: background-color 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
    box-shadow: 0 0 0 0 transparent;
  }

  .tl-item:hover button.tl-anchor::after {
    background-color: var(--bronze-9);
    transform: translate(-50%, -50%) scale(1.3);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--bronze-9) 20%, transparent);
  }

  /* Tooltip — slide up + fade in */
  button.tl-anchor::before {
    content: '复制链接';
    position: absolute;
    left: 50%;
    bottom: calc(100% + 4px);
    transform: translateX(-50%) translateY(4px);
    font-size: 0.7rem;
    white-space: nowrap;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    background-color: var(--sand-12);
    color: var(--sand-1);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  button.tl-anchor:hover::before {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Copied feedback — pop + sustained glow */
  button.tl-anchor.tl-anchor-copied::before {
    content: '已复制 ✓';
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  button.tl-anchor.tl-anchor-copied::after {
    background-color: var(--grass-9);
    animation: anchor-pop 1.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes anchor-pop {
    0%   { transform: translate(-50%, -50%) scale(2);   box-shadow: 0 0 0 10px color-mix(in srgb, var(--grass-9) 35%, transparent); }
    15%  { transform: translate(-50%, -50%) scale(1.15); box-shadow: 0 0 0 4px color-mix(in srgb, var(--grass-9) 25%, transparent); }
    25%  { transform: translate(-50%, -50%) scale(1.5);  box-shadow: 0 0 0 6px color-mix(in srgb, var(--grass-9) 20%, transparent); }
    40%  { transform: translate(-50%, -50%) scale(1.3);  box-shadow: 0 0 0 5px color-mix(in srgb, var(--grass-9) 18%, transparent); }
    70%  { transform: translate(-50%, -50%) scale(1.3);  box-shadow: 0 0 0 5px color-mix(in srgb, var(--grass-9) 15%, transparent); }
    100% { transform: translate(-50%, -50%) scale(1);    box-shadow: 0 0 0 0 transparent; }
  }

  /* Highlight when scrolled to / copied — hold then fade */
  .tl-highlight {
    border-color: var(--bronze-7) !important;
    box-shadow: 0 0 0 2px var(--bronze-4) !important;
    animation: anchor-highlight 2.5s ease-out forwards;
  }

  @keyframes anchor-highlight {
    0%   { border-color: var(--bronze-9); box-shadow: 0 0 0 4px color-mix(in srgb, var(--bronze-7) 35%, transparent); }
    15%  { border-color: var(--bronze-8); box-shadow: 0 0 0 3px color-mix(in srgb, var(--bronze-7) 25%, transparent); }
    55%  { border-color: var(--bronze-7); box-shadow: 0 0 0 2px var(--bronze-4); }
    100% { border-color: var(--sand-4);   box-shadow: 0 0 0 0 transparent; }
  }

  .tl-item:hover .tl-dot:not(.tl-anchor) {
    background-color: var(--bronze-9);
    transform: scale(1.3);
  }

  .tl-content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.75rem 1rem;
    flex: 1;
    min-width: 0;
    background-color: var(--sand-2);
    border: 1px solid var(--sand-4);
    border-radius: 0.625rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tl-item:hover .tl-content {
    border-color: var(--sand-6);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .tl-date {
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: var(--sand-9);
  }

  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tl-tag {
    font-size: 0.7rem;
    color: var(--grass-11);
    background-color: var(--sand-3);
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
  }

  .tl-body {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--sand-12);
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .tl-body p {
    margin: 0.25rem 0;
  }

  .tl-body p:first-child {
    margin-top: 0;
  }

  .tl-body p:last-child {
    margin-bottom: 0;
  }

  .tl-body ul,
  .tl-body ol {
    margin: 0.25rem 0;
    padding-left: 1.25rem;
  }

  .tl-body blockquote {
    margin: 0.5rem 0;
    padding-left: 0.75rem;
    border-left: 3px solid var(--sand-6);
    color: var(--sand-10);
  }

  .tl-body pre {
    margin: 0.5rem 0;
    padding: 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    background-color: var(--sand-3);
    overflow-x: auto;
  }

  .tl-body code:not(pre code) {
    font-size: 0.8rem;
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    background-color: var(--sand-3);
  }

  .tl-body a {
    color: var(--grass-11);
    text-decoration: underline;
    text-decoration-color: var(--sand-6);
    text-underline-offset: 2px;
  }

  .tl-body a:hover {
    text-decoration-color: var(--grass-11);
  }

  .tl-body img {
    max-width: 100%;
    border-radius: 0.375rem;
    margin: 0.5rem 0;
  }

  .tl-body ul.contains-task-list {
    list-style: none;
    padding-left: 0;
  }

  .tl-body input[type="checkbox"] {
    margin-right: 0.375rem;
  }

  /* Skeleton loading */
  .skeleton {
    background: linear-gradient(90deg, var(--sand-3) 25%, var(--sand-4) 50%, var(--sand-3) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 0.25rem;
  }

  .skeleton-date {
    width: 8rem;
    height: 0.75rem;
  }

  .skeleton-body {
    width: 100%;
    max-width: 24rem;
    height: 1rem;
    margin-top: 0.25rem;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script>
  import MarkdownIt from 'markdown-it';
  import githubAlerts from 'markdown-it-github-alerts';

  // --- Markdown 渲染器（轻量版，不含语法高亮） ---
  let md: MarkdownIt | null = null;

  function getMd(): MarkdownIt {
    if (md) return md;

    md = new MarkdownIt({ html: true, linkify: true, breaks: true });
    md.enable(['strikethrough']);
    md.use(githubAlerts);

    return md;
  }

  interface Memo {
    name: string;
    content: string;
    displayTime: string;
    tags: string[];
    pinned: boolean;
    snippet: string;
  }

  function formatDate(iso: string): string {
    const d = new Date(iso);
    const pad = (n: number) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  function getMemoId(memo: Memo): string {
    // memo.name is like "memos/123"
    return memo.name.replace('/', '-');
  }

  function renderMemoItem(renderer: MarkdownIt, memo: Memo): string {
    const html = renderer.render(memo.content);
    const id = getMemoId(memo);
    const tagsHtml = memo.tags.length > 0
      ? `<div class="tl-tags">${memo.tags.map((t) => `<span class="tl-tag">#${t}</span>`).join('')}</div>`
      : '';

    return `
      <div class="tl-item" id="${id}">
        <button class="tl-dot tl-anchor" data-id="${id}" title="复制链接" aria-label="复制此条 Memo 的链接"></button>
        <div class="tl-content">
          <span class="tl-date">${formatDate(memo.displayTime)}</span>
          ${tagsHtml}
          <div class="tl-body">${html}</div>
        </div>
      </div>`;
  }

  // --- Tab switching ---
  const tabPosts = document.getElementById('tab-posts')!;
  const tabMemos = document.getElementById('tab-memos')!;
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-tab]');

  function switchTab(tab: 'posts' | 'memos') {
    const isPosts = tab === 'posts';
    tabPosts.classList.toggle('tab-hidden', !isPosts);
    tabMemos.classList.toggle('tab-hidden', isPosts);

    navLinks.forEach((link) => {
      const isActive = link.dataset.tab === tab;
      if (isActive) {
        link.classList.add('shadow-border', 'bg-white', 'dark:bg-sand-4');
        link.classList.remove('hover:bg-sand-3', 'dark:hover:bg-sand-4');
        link.style.color = 'var(--sand-12)';
      } else {
        link.classList.remove('shadow-border', 'bg-white', 'dark:bg-sand-4');
        link.classList.add('hover:bg-sand-3', 'dark:hover:bg-sand-4');
        link.style.color = 'var(--sand-11)';
      }
    });

    if (tab === 'memos' && !memosLoaded) {
      loadMemos();
    }
  }

  navLinks.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const tab = link.dataset.tab as 'posts' | 'memos';
      history.replaceState(null, '', tab === 'memos' ? '/memo' : '/post');
      switchTab(tab);
    });
  });

  function handlePath() {
    const path = window.location.pathname.replace(/\/+$/, '');
    const hasMemoHash = location.hash.startsWith('#memos-');
    switchTab(path === '/memo' || hasMemoHash ? 'memos' : 'posts');
  }

  // --- Memos: 直连 Memos API ---
  let memosLoaded = false;
  const apiUrl = tabMemos.dataset.api!;

  async function loadMemos() {
    const loading = document.getElementById('memo-loading')!;
    const error = document.getElementById('memo-error')!;
    const list = document.getElementById('memo-list')!;

    try {
      // 并行：初始化渲染器 + 获取数据
      const [renderer, allMemos] = await Promise.all([getMd(), fetchAllMemos()]);

      if (allMemos.length === 0) {
        loading.classList.add('tab-hidden');
        error.classList.remove('tab-hidden');
        return;
      }

      list.innerHTML = allMemos.map((m) => renderMemoItem(renderer, m)).join('');
      loading.classList.add('tab-hidden');
      list.classList.remove('tab-hidden');
      memosLoaded = true;

      // Anchor click → copy link
      list.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tl-anchor');
        if (!btn) return;
        const id = btn.dataset.id!;
        const url = `${location.origin}/memo#${id}`;
        navigator.clipboard.writeText(url).then(() => {
          btn.classList.add('tl-anchor-copied');
          setTimeout(() => btn.classList.remove('tl-anchor-copied'), 1500);

          const card = btn.closest('.tl-item')?.querySelector('.tl-content');
          card?.classList.remove('tl-highlight');
          void (card as HTMLElement)?.offsetWidth; // reflow to restart animation
          card?.classList.add('tl-highlight');
          card?.addEventListener('animationend', () => card.classList.remove('tl-highlight'), { once: true });
        });
      });

      // Scroll to anchor if hash present
      scrollToHash();
    } catch {
      loading.classList.add('tab-hidden');
      error.classList.remove('tab-hidden');
    }
  }

  async function fetchAllMemos(): Promise<Memo[]> {
    const allMemos: Memo[] = [];
    let pageToken = '';

    do {
      const url = new URL(`${apiUrl}/api/v1/memos`);
      url.searchParams.set('pageSize', '50');
      if (pageToken) url.searchParams.set('pageToken', pageToken);

      const res = await fetch(url.toString());
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json();
      allMemos.push(...(data.memos || []));
      pageToken = data.nextPageToken || '';
    } while (pageToken);

    // Pinned first, then newest
    allMemos.sort((a, b) => {
      if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
      return b.displayTime.localeCompare(a.displayTime);
    });

    return allMemos;
  }

  function scrollToHash() {
    const hash = location.hash.slice(1);
    if (!hash) return;
    const el = document.getElementById(hash);
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      const card = el.querySelector('.tl-content');
      card?.classList.add('tl-highlight');
      card?.addEventListener('animationend', () => card.classList.remove('tl-highlight'), { once: true });
    }
  }

  handlePath();
</script>

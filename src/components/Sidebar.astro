---
import ThemeToggle from './ThemeToggle.astro';
import ActivityGraph from './ActivityGraph.astro';
import { siteConfig } from '../lib/config';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navIcons: Record<string, string> = {
  Post: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  Memo: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="11" y="3" width="2" height="18" rx="1"/><rect x="11" y="3" width="2" height="18" rx="1" transform="rotate(60 12 12)"/><rect x="11" y="3" width="2" height="18" rx="1" transform="rotate(120 12 12)"/></svg>',
  RSS: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>',
  GitHub: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>',
};

const internalLinks = siteConfig.navLinks.filter((l) => !l.external);
const externalLinks = siteConfig.navLinks.filter((l) => l.external);

function isActive(href: string): boolean {
  if (href === '/post') {
    return currentPath === '/' || currentPath.startsWith('/post');
  }
  return false;
}
---

<aside class="hidden lg:flex lg:flex-col lg:w-48 xl:w-56 p-3 min-h-screen scrollable-area">
  <!-- Logo + Title + Theme Toggle -->
  <div class="flex items-center gap-2.5 py-6 px-2">
    <a href="/" class="shrink-0">
      <img
        src={siteConfig.avatar}
        alt={siteConfig.title}
        class="w-10 h-10 rounded-full object-cover"
        style="box-shadow: 0 0 0 2px var(--sand-6);"
      />
    </a>
    <h1 class="text-sm font-semibold flex-1" style="color: var(--bronze-12);">
      {siteConfig.title}
    </h1>
    <ThemeToggle />
  </div>

  <!-- Navigation -->
  <nav class="flex flex-col gap-1 flex-1">
    {internalLinks.map((link) => {
      const tabName = link.href === '/post' ? 'posts' : link.href === '/memo' ? 'memos' : undefined;
      const active = isActive(link.href);

      return (
        <a
          href={link.href}
          data-tab={tabName}
          class={[
            'flex items-center gap-2 rounded-xl py-2 px-4 text-sm font-medium transition-colors duration-100',
            active
              ? 'shadow-border bg-white dark:bg-sand-4'
              : 'hover:bg-sand-3 dark:hover:bg-sand-4',
          ].join(' ')}
          style={`color: ${active ? 'var(--sand-12)' : 'var(--sand-11)'};`}
        >
          <Fragment set:html={navIcons[link.label] || ''} />
          {link.label}
        </a>
      );
    })}
  </nav>

  <!-- Bottom area -->
  <div class="mt-auto px-2 pt-4 pb-2 flex flex-col gap-3">
    <!-- Activity Graph -->
    <div>
      <h3 class="text-xs font-medium mb-2" style="color: var(--sand-9);">Activity</h3>
      <ActivityGraph />
    </div>

    <!-- External icon links -->
    <div class="flex items-center gap-1">
      {externalLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="sidebar-icon-link"
          aria-label={link.label}
          title={link.label}
        >
          <Fragment set:html={navIcons[link.label] || ''} />
        </a>
      ))}
    </div>
  </div>
</aside>

<style>
  .sidebar-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border-radius: 8px;
    color: var(--sand-9);
    transition: color 0.15s, background-color 0.15s;
  }
  .sidebar-icon-link:hover {
    color: var(--sand-12);
    background-color: var(--sand-3);
  }
</style>

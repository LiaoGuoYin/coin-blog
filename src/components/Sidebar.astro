---
import ThemeToggle from './ThemeToggle.astro';
import { siteConfig } from '../lib/config';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/post') {
    return currentPath === '/' || currentPath.startsWith('/post');
  }
  return false;
}
---

<aside class="hidden lg:flex lg:flex-col lg:w-48 xl:w-56 p-3 min-h-screen scrollable-area">
  <!-- Logo + Title -->
  <div class="flex items-center gap-2.5 py-6 px-2">
    <a href="/" class="shrink-0">
      <img
        src={siteConfig.avatar}
        alt={siteConfig.title}
        class="w-10 h-10 rounded-full object-cover"
        style="box-shadow: 0 0 0 2px var(--sand-6);"
      />
    </a>
    <h1 class="text-sm font-semibold" style="color: var(--bronze-12);">
      {siteConfig.title}
    </h1>
  </div>

  <!-- Navigation -->
  <nav class="flex flex-col gap-1 flex-1">
    {siteConfig.navLinks.map((link) => {
      const tabName = link.href === '/post' ? 'posts' : link.href === '/memo' ? 'memos' : undefined;
      const active = isActive(link.href);

      return (
        <a
          href={link.href}
          data-tab={tabName}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class={[
            'rounded-xl py-2 px-4 text-sm font-medium transition-colors duration-100',
            active
              ? 'shadow-border bg-white dark:bg-sand-4'
              : 'hover:bg-sand-3 dark:hover:bg-sand-4',
          ].join(' ')}
          style={`color: ${active ? 'var(--sand-12)' : 'var(--sand-11)'};`}
        >
          {link.label}
        </a>
      );
    })}
  </nav>

  <!-- Theme Toggle at bottom -->
  <div class="mt-auto pt-4 pb-2 flex justify-start px-2">
    <ThemeToggle />
  </div>
</aside>

---
import { formatDate } from '../lib/posts';
import type { Post } from '../lib/posts';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<ul class="flex flex-col gap-0 list-none m-0 p-0">
  {posts.map((post) => (
    <li>
      <a
        href={`/${post.slug}`}
        class="flex gap-4 justify-between items-center rounded-md p-2 -mx-2 transition-colors duration-100"
        style="text-decoration: none;"
        onmouseover="this.style.backgroundColor='var(--sand-3)'"
        onmouseout="this.style.backgroundColor=''"
      >
        <span class="truncate text-sm" style="color: var(--sand-12);">{post.title}</span>
        <span
          class="flex-1 border-b border-dashed"
          style="border-color: var(--sand-6); min-width: 1rem;"
        ></span>
        <span class="font-mono flex-shrink-0 text-sm" style="color: var(--sand-11);">
          {formatDate(post.date)}
        </span>
      </a>
    </li>
  ))}
</ul>
